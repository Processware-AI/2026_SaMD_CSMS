# ==========================================
# macOS
# ==========================================
.DS_Store
._*
.Spotlight-V100
.Trashes

# ==========================================
# 고객 입력자료 (저작권·기밀)
# 스텁 README / .gitkeep 만 버전 관리
# ==========================================
vault/_inputs_common/*
!vault/_inputs_common/README.md
!vault/_inputs_common/.gitkeep

vault/02_표준/**/_inputs/*
!vault/02_표준/**/_inputs/README.md
!vault/02_표준/**/_inputs/.gitkeep

# ==========================================
# 파이프라인 실행 상태 (인스턴스별)
# ==========================================
vault/02_표준/**/_state*.yaml
vault/02_표준/**/99_QA리포트_*.md
vault/02_표준/**/02_작업노트.md

# ==========================================
# Obsidian 워크스페이스 (개인 환경)
# ==========================================
.obsidian/workspace*
.obsidian/cache/
.obsidian/appearance.json
.obsidian/hotkeys.json

# ==========================================
# 환경·로그·임시
# ==========================================
*.log
*.tmp
.env
.env.local
.env.*.local
*.swp
*.swo

# ==========================================
# Claude Code 세션 캐시 (로컬만)
# ==========================================
.claude/sessions/
.claude/cache/

# ==========================================
# 의존성·빌드 (향후 프레임워크화 대비)
# ==========================================
node_modules/
__pycache__/
*.pyc
.venv/
venv/
dist/
build/
